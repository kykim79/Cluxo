    "좌클릭 길게": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Long left-click"
          }
        }
      }
    },
    "끄기 (단축키만)": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Off (shortcut only)"
