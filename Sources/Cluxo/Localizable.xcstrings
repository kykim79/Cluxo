      }
    },
    "링의 형태(원·둥근 사각형·마름모·육각형)를 바꿉니다.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Change the ring shape (circle, rounded square, rhombus, hexagon)."
          }
        }
      }
    },
    "링이 맥박처럼 숨쉼 — 대기 중": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ring breathes like a pulse — idle"
          }
        }
      }
    },
    "마름모": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rhombus"
          }
        }
      }
    },
    "마무리 중...": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Finishing up..."
          }
        }
      }
    },
    "마우스 커서 주변 링의 기본 색. ⌃⌥1~6 단축키 또는 라디얼 메뉴(⌃⌥,)로 빠르게 전환. 클릭/드래그/그리기 등 모든 강조 효과가 이 색을 따릅니다.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Base color of the ring around the cursor. Switch quickly with ⌃⌥1–6 or the radial menu (⌃⌥,). All click/drag/drawing highlights follow this color."
          }
        }
      }
    },
    "마우스를 빠르게 여러 번 흔들면 커서 위치에 퍼지는 링 표시. 커서를 놓쳤을 때 찾기 좋음.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quickly shake the mouse several times to show expanding rings at the cursor — handy when you lose track of the cursor."
          }
        }
      }
    },
    "마우스를 안 움직인 후 링이 페이드 아웃되기까지 대기 시간. 발표 중엔 길게(5초+) 권장.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How long to wait after mouse stops before the ring fades out. 5s+ is recommended during presentations."
          }
        }
      }
    },
    "매우 크게": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extra Large"
          }
        }
      }
    },
    "매우 크게 (96pt)": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extra Large (96pt)"
          }
        }
      }
    },
    "메인 링 안쪽에 반투명 보조 선을 추가해 두께감 보강.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adds a translucent inner ring to reinforce thickness."
          }
        }
      }
    },
    "모드": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Modes"
          }
        }
      }
    },
    "모든 단축키는 ⌃⌥ (Control+Option) + 아래 키 조합입니다. 클릭하고 원하는 키를 누르세요. ESC로 캡처 취소.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All shortcuts use ⌃⌥ (Control+Option) plus the key below. Click a row, then press the key you want. ESC to cancel capture."
          }
        }
      }
    },
    "모든 패널 열기": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open All Panels"
          }
        }
      }
    },
    "모양": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Appearance"
          }
        }
      }
    },
    "모양 순환": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cycle Shape"
          }
        }
      }
    },
    "민감": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sensitive"
          }
        }
      }
    },
    "민감하면 살짝 흔들어도 발동, 둔감하면 여러 번 빠르게 흔들어야 발동. 오발동이 잦으면 둔감 쪽으로.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
